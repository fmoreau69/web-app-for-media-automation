# Normalisation des fins de ligne : tout texte stocké en LF dans le dépôt.
# (HEAD est déjà en LF ; ceci empêche la dérive CRLF des éditeurs Windows.)
* text=auto eol=lf

# Scripts Windows : conserver CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

