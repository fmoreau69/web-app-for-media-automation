# =============================================================================
# AI Models - Git Ignore Configuration
# =============================================================================
# This file excludes large AI model files from Git while preserving
# the directory structure needed for the application to function.
#
# Models are downloaded automatically when needed by WAMA.
#
# Directory layout:
#   models/
#     diffusion/    - Image & Video generation (SD, FLUX, Wan, Hunyuan, etc.)
#     llm/          - Large Language Models (reserved)
#     speech/       - TTS & STT (Coqui XTTS, Bark, Whisper, Higgs, VibeVoice)
#     upscaling/    - Super-resolution (ONNX enhancer models)
#     vision/       - Detection, Segmentation, Pose (YOLO, SAM)
#     vision-language/ - Captioning & NLP (BLIP, BART, BERT)
#   cache/          - HuggingFace download cache
#   external/       - External tools
# =============================================================================

# -----------------------------------------------------------------------------
# Global: Common AI model file formats (catches everything)
# -----------------------------------------------------------------------------
*.pt
*.pth
*.bin
*.safetensors
*.h5
*.pb
*.tflite
*.onnx
*.engine
*.mlmodel
*.caffemodel
*.pkl
*.pickle
*.npy
*.npz
*.gguf
*.ggml

# -----------------------------------------------------------------------------
# HuggingFace cache & hub artifacts
# -----------------------------------------------------------------------------
cache/
models--*/
.locks/
xet/
hub/

# -----------------------------------------------------------------------------
# models/speech/ - TTS & STT
# -----------------------------------------------------------------------------
models/speech/coqui/
models/speech/bark/
models/speech/whisper/
models/speech/higgs/
models/speech/vibevoice/

# -----------------------------------------------------------------------------
# models/diffusion/ - Image & Video generation
# -----------------------------------------------------------------------------
models/diffusion/stable-diffusion/
models/diffusion/flux/
models/diffusion/wan/
models/diffusion/hunyuan/
models/diffusion/cogvideox/
models/diffusion/ltx/
models/diffusion/mochi/
models/diffusion/logo/

# -----------------------------------------------------------------------------
# models/vision/ - Detection, Segmentation, Pose
# -----------------------------------------------------------------------------
models/vision/yolo/
models/vision/sam/

# -----------------------------------------------------------------------------
# models/upscaling/ - Super-resolution ONNX models
# -----------------------------------------------------------------------------
models/upscaling/

# -----------------------------------------------------------------------------
# models/vision-language/ - Captioning & NLP
# -----------------------------------------------------------------------------
models/vision-language/bart/
models/vision-language/bert/
models/vision-language/blip/

# -----------------------------------------------------------------------------
# models/llm/ - Large Language Models
# -----------------------------------------------------------------------------
models/llm/

# -----------------------------------------------------------------------------
# External tools
# -----------------------------------------------------------------------------
external/

# -----------------------------------------------------------------------------
# Exceptions - Keep these files tracked
# -----------------------------------------------------------------------------
!.gitignore
!.gitkeep
!README.md
!*.md
!*/.gitkeep
!*/*/.gitkeep
!*/*/*/.gitkeep
!*/*/*/*/.gitkeep
