# ============================================================================
# WAMA — modèle de configuration d'environnement.
# Copier en `.env` (gitignoré) et remplir les valeurs. NE JAMAIS commiter `.env`.
#   cp .env.example .env
# ============================================================================

# ── API Anthropic (chat IA) — optionnel ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Django ──────────────────────────────────────────────────────────────────
# Générer : python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
# (ou rotation automatique : python manage.py rotate_secrets --secret-key)
DJANGO_SECRET_KEY=
# Anciennes clés (rotation sans invalider les sessions). Rempli automatiquement
# par rotate_secrets ; séparées par des espaces/virgules.
# DJANGO_SECRET_KEY_FALLBACKS=

# ── Base de données PostgreSQL ──────────────────────────────────────────────
WAMA_DB_NAME=wama_db
WAMA_DB_USER=wama_user
WAMA_DB_PASSWORD=
WAMA_DB_HOST=127.0.0.1
WAMA_DB_PORT=5432

# ── Proxy réseau (optionnel — assets vendorés, apt/pip en WSL) ───────────────
PROXY=
HTTP_PROXY=

# ── LDAP université (optionnel — défauts dans settings.py) ───────────────────
# WAMA_LDAP_URI=ldap://ldap.exemple.fr
# WAMA_LDAP_STRUCTURES_DN=ou=structures,dc=exemple,dc=fr

# ── Ollama (assistant IA local) ─────────────────────────────────────────────
# OLLAMA_HOST=http://127.0.0.1:11434

# ── Email SMTP (notifications modération) — optionnel ───────────────────────
# WAMA_EMAIL_HOST=
# WAMA_EMAIL_PORT=587
# WAMA_EMAIL_USER=
# WAMA_EMAIL_PASSWORD=
# WAMA_EMAIL_FROM=WAMA <no-reply@exemple.fr>
# WAMA_MODERATOR_EMAILS=

# ── wama-dev-ai (agent local) — optionnel ───────────────────────────────────
WAMA_USERNAME=
# WAMA_PASSWORD=
